{
  "name": "@static-extract/extractor-ts",
  "version": "0.0.1",
  "type": "module",
  "description": "TypeScript/JavaScript AST extractor for Static Extract SER rules.",
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./cli": "./cli/static-extract-ts.mjs"
  },
  "bin": {
    "static-extract-ts": "./cli/static-extract-ts.mjs"
  },
  "files": [
    "index.mjs",
    "index.d.ts",
    "cli/",
    "extractor/",
    "dist/",
    "rules/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "generate:ser-parser": "antlr-ng -D language=TypeScript -v -o src/generated/ser ../spec/ser/Ser.g4",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node test/spec-contract.test.mjs && node test/e2e-ser-authoring.test.mjs && node test/module-api.test.mjs"
  },
  "dependencies": {
    "antlr4ng": "^3.0.16",
    "ts-morph": "^24.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "antlr-ng": "^1.0.10",
    "typescript": "^6.0.3"
  }
}
